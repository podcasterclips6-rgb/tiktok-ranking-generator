# Server Configuration
PORT=5000
NODE_ENV=development

# Video Output
OUTPUT_DIR=./output
TEMP_DIR=./temp
UPLOADS_DIR=./uploads

# Video Settings
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
CLIP_DURATION=5
TOTAL_CLIPS=5
TOTAL_DURATION=25
VIDEO_CODEC=libx264
VIDEO_PRESET=medium

# FFmpeg Path (leave empty to use system FFmpeg)
FFMPEG_PATH=

# CORS
CORS_ORIGIN=http://localhost:3000
